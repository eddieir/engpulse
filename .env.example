# ─────────────────────────────────────────────────────────────────────────────
# EngPulse — Environment Variables
#
# Copy this file to .env.local for local development.
# In Netlify: set all variables in Site Settings → Environment Variables.
#
# REQUIRED = app will not function without this variable
# OPTIONAL = has a safe fallback, but should be set in production
# ─────────────────────────────────────────────────────────────────────────────


# ── Site ─────────────────────────────────────────────────────────────────────

# REQUIRED — Production URL (no trailing slash).
# Used in: email verification links, OG tags, sitemap, canonical URLs, JSON-LD.
# In Netlify: set this to your custom domain or the Netlify site URL.
# Must be set BEFORE the build runs so static pages bake the correct URLs.
NEXT_PUBLIC_SITE_URL=https://engplus.netlify.app


# ── Supabase ──────────────────────────────────────────────────────────────────

# REQUIRED — Your Supabase project REST endpoint.
# Found in: Supabase dashboard → Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://bwwmdrzsedufwrbzasky.supabase.co

# OPTIONAL — Supabase anon (public) key. Safe to expose to the browser.
# Currently unused in API routes (service role is used instead).
# Keep for future client-side queries.
# Found in: Supabase dashboard → Project Settings → API → anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ3d21kcnpzZWR1ZndyYnphc2t5Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgyMzMwMTUsImV4cCI6MjA5MzgwOTAxNX0.PObPLw4g-jC43864lxc4tRUtXBnZwOfKq0YlvU76dCw

# REQUIRED — Supabase service role key. NEVER expose to the browser.
# Used in: all API routes and the Edge proxy to bypass RLS.
# Found in: Supabase dashboard → Project Settings → API → service_role key.
# In Netlify: mark as "secret" / do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ3d21kcnpzZWR1ZndyYnphc2t5Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3ODIzMzAxNSwiZXhwIjoyMDkzODA5MDE1fQ.c_UpnhvC_4QaYc7I47fP5gQ4G8FXRyfW5ZK9HAuvZzc


# ── Email (Resend) ────────────────────────────────────────────────────────────

# REQUIRED — Resend API key for transactional email.
# Used in: verification emails, access-activated emails, pricing notifications.
# Found in: resend.com → API Keys.
RESEND_API_KEY=re_your_api_key

# OPTIONAL — From address for all outbound emails.
# Must match a verified domain in Resend.
# Default: EngPulse <noreply@engpulse.io>
EMAIL_FROM=EngPulse <noreply@engpulse.io>


# ── Pricing notifications ─────────────────────────────────────────────────────

# OPTIONAL — Email address to receive internal pricing inquiry notifications.
# Default: falls back to EMAIL_FROM.
PRICING_TEAM_EMAIL=peyman.iravani@gmail.com


# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# OPTIONAL — When not set, the app uses simulated demo mode for GitHub connect.
# When set, users are redirected to real GitHub OAuth.
# NOTE: The callback handler (/api/github/callback) still has a TODO for the
# full token exchange. Set these once that flow is implemented.

# Found in: GitHub → Settings → Developer settings → OAuth Apps → Client ID.
GITHUB_CLIENT_ID=your-github-client-id

# REQUIRED if GITHUB_CLIENT_ID is set. NEVER expose to the browser.
# Found in: GitHub → Settings → Developer settings → OAuth Apps → Client Secret.
GITHUB_CLIENT_SECRET=your-github-client-secret


# ── Admin ─────────────────────────────────────────────────────────────────────

# REQUIRED in production — Password for /internal/admin.
# If not set, the admin page is open to anyone (dev convenience only).
# In Netlify: mark as "secret".
INTERNAL_ADMIN_PASSWORD=change-this-to-a-strong-password


# ── Netlify Functions ─────────────────────────────────────────────────────────

# OPTIONAL — Admin debug key to protect the health-check endpoint.
# In Netlify: mark as "secret".
# Usage: curl -H "x-debug-key: VALUE" https://your-site/.netlify/functions/health-check
ADMIN_DEBUG_KEY=change-this-to-a-random-secret
